{
  "name": "eid-cli",
  "version": "0.2.1",
  "description": "Eid CLI with Hijri-aware Eid, Shawwal, and Islamic date status.",
  "type": "module",
  "bin": {
    "eid-cli": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "eid",
    "eid-mubarak",
    "shawwal",
    "hijri",
    "islamic-calendar",
    "cli"
  ],
  "author": "muhmp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhmp/eid-cli.git"
  },
  "homepage": "https://github.com/muhmp/eid-cli#readme",
  "bugs": {
    "url": "https://github.com/muhmp/eid-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "@types/node": "^22.18.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "commander": "^14.0.1",
    "conf": "^14.0.0",
    "picocolors": "^1.1.1",
    "zod": "^4.1.11"
  }
}
